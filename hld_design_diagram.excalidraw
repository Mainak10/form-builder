      "type": "text",
      "x": 105,
      "y": 330,
      "width": 279,
      "height": 293,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "BuilderState (useReducer)\n• schema: FormSchema\n• selectedFieldId: string | null\n• isDirty: boolean\n• schemaErrors: SchemaError[]\n\nPalette → drop/click\n   ↓ FIELD_ADD\nCanvas ↔ ConfigPanel\n   ↓ reorder / edit\nBuilderReducer + CascadeCleanup\n   ↓\nFormSchema (in-memory)\n   ↓ SAVE\nlocalStorage",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "BuilderState (useReducer)\n• schema: FormSchema\n• selectedFieldId: string | null\n• isDirty: boolean\n• schemaErrors: SchemaError[]\n\nPalette → drop/click\n   ↓ FIELD_ADD\nCanvas ↔ ConfigPanel\n   ↓ reorder / edit\nBuilderReducer + CascadeCleanup\n   ↓\nFormSchema (in-memory)\n   ↓ SAVE\nlocalStorage",
      "lineHeight": 1.25,
      "index": "a7",
      "id": "5NBIeWa7UQaNBjE766-Dh",
      "autoResize": true
    },
